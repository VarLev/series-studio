# === Series Studio — переменные окружения (TZ §12) ===

# Anthropic API — сюжеты, раскадровка, промпт-фабрика (модели claude-*).
# Без ключа приложение работает, но LLM-кнопки вернут понятную ошибку.
ANTHROPIC_API_KEY=

# OpenAI API — нужен, если GPT-модель (gpt-*, напр. GPT-5.6 Sol) идёт через API,
# а НЕ через Codex CLI (см. ниже), а также для vision-задач на GPT. Оплата OpenAI
# отдельная от Anthropic. Модели claude-* ключ OpenAI не требуют.
# Ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# GPT через OpenAI Codex CLI (подписка ChatGPT Plus/Pro вместо API-денег) —
# аналог Claude Code CLI. По умолчанию (настройка llm_use_cli_gpt на /costs) все
# текстовые GPT-запросы идут через CLI: ключ OPENAI_API_KEY тогда НЕ нужен, но
# требуется разовый вход `codex login` (аккаунт с подпиской ChatGPT). CLI ставится
# локально в node_modules (@openai/codex, devDependency) — отдельно ставить не надо.
# Необязательные переопределения:
#   CODEX_CLI_PATH — явный путь к бинарю codex (если не найден автоматически)
#   CODEX_REASONING_EFFORT — переопределить уровень «рассуждения» для ВСЕХ вызовов:
#     none|low|medium|high|xhigh|max. По умолчанию сложные вызовы (разбивка, Enhance,
#     вставки, промпт) идут на high, механический реворк — на low.
CODEX_CLI_PATH=
CODEX_REASONING_EFFORT=

# DeepSeek API — нужен, если в «Настройки → Модель для простых запросов»
# выбрана DeepSeek (deepseek-v4-pro / deepseek-v4-flash). Дёшево, но БЕЗ
# картинок: анализ референсов автоматически идёт через Haiku 4.5.
# Ключ: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Пароль входа (одно-пользовательский режим). Если не задан — вход без пароля (локальная разработка).
APP_PASSWORD=

# Telegram-уведомление об адресе туннеля (mobile.cmd). При запуске cloudflared
# скрипт scripts/mobile-tunnel.ps1 ловит https://xxxx.trycloudflare.com и шлёт
# его вам в бот — не нужно смотреть в окно на ПК, ссылка приходит на телефон.
# 1) Создайте бота у @BotFather → он даст токен вида 123456:ABC... → сюда.
# 2) Напишите своему боту любое сообщение (иначе он не может писать вам первым).
# 3) TELEGRAM_CHAT_ID можно не заполнять — скрипт определит его из вашего
#    сообщения и подскажет значение (впишите, чтобы не искать при каждом запуске).
# Если TELEGRAM_BOT_TOKEN пуст — туннель работает как раньше, просто без отправки.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Прод (Vercel + Supabase). Не заданы → локальный режим: PGlite + файлы в .data/ ---
# Supabase Postgres (используйте pooled-строку, порт 6543)
DATABASE_URL=
# Supabase Storage для референсов и результатов
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=media

# --- Этап 2 (генерация видео Higgsfield) ---
# Без ключа приложение работает на MockProvider (генерация имитируется сэмплом) —
# удобно для локальной проверки конвейера. С ключом идёт реальный Cloud API.
# Ключ берётся в дашборде Higgsfield Cloud (https://cloud.higgsfield.ai) и выдаётся
# как HF_KEY в формате «key:secret» — вставьте его целиком в HIGGSFIELD_API_KEY
# (тогда HIGGSFIELD_API_SECRET можно не заполнять). Заголовок: Authorization: Key <...>.
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
# Принудительно включить мок даже при наличии ключа:
HIGGSFIELD_MOCK=
# Переопределить базовый URL Cloud API (по умолчанию https://platform.higgsfield.ai):
HIGGSFIELD_BASE_URL=

# --- Nano Banana через Google Gemini API (дешевле, бережёт кредиты Higgsfield) ---
# Ключ из Google AI Studio: https://aistudio.google.com/apikey
# Если задан — раскадровки и референсы (Nano Banana Pro/Light) идут напрямую в Gemini
# (pay-per-use у Google, $0.04–0.24 за картинку). Если пусто — Nano Banana идёт через
# Higgsfield (кредиты подписки) или мок. Видео всегда через Higgsfield.
GEMINI_API_KEY=
# Принудительно вернуть Nano Banana на Higgsfield/мок даже при наличии ключа:
GEMINI_MOCK=
# Переопределить базовый URL (по умолчанию https://generativelanguage.googleapis.com/v1beta):
GEMINI_BASE_URL=

# Секрет для фонового поллинга (Supabase pg_cron / планировщик) и вебхука Higgsfield.
# Роут /api/generations/poll принимает заголовок x-cron-secret; вебхук — ?secret=
CRON_SECRET=
