# === Series Studio — переменные окружения (TZ §12) ===

# Anthropic API — сюжеты, раскадровка, промпт-фабрика.
# Без ключа приложение работает, но LLM-кнопки вернут понятную ошибку.
ANTHROPIC_API_KEY=

# Пароль входа (одно-пользовательский режим). Если не задан — вход без пароля (локальная разработка).
APP_PASSWORD=

# --- Прод (Vercel + Supabase). Не заданы → локальный режим: PGlite + файлы в .data/ ---
# Supabase Postgres (используйте pooled-строку, порт 6543)
DATABASE_URL=
# Supabase Storage для референсов и результатов
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=media

# --- Этап 2 (генерация Higgsfield) ---
# Без ключа приложение работает на MockProvider (генерация имитируется сэмплом) —
# удобно для локальной проверки конвейера. С ключом идёт реальный Cloud API.
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
# Принудительно включить мок даже при наличии ключа:
HIGGSFIELD_MOCK=
# Переопределить базовый URL Cloud API (по умолчанию https://platform.higgsfield.ai):
HIGGSFIELD_BASE_URL=

# Секрет для фонового поллинга (Supabase pg_cron / планировщик) и вебхука Higgsfield.
# Роут /api/generations/poll принимает заголовок x-cron-secret; вебхук — ?secret=
CRON_SECRET=
